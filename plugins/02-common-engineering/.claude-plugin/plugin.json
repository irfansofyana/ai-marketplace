{
  "name": "common-engineering",
  "description": "Foundational engineering tools for diagram generation, documentation, and common development tasks",
  "version": "1.0.0",
  "author": {
    "name": "irfansofyana"
  },
  "mcpServers": {
		"exa": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"mcp-remote",
				"https://mcp.exa.ai/mcp?exaApiKey=${EXA_API_KEY}&tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
			],
			"env": {
				"EXA_API_KEY": "${EXA_API_KEY}"
			}
    	}
	}
}
